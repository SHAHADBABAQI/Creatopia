            "value" : "صندوق الكنز"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Treasure Box"
          }
        }
      }
    },
    "instruction.museum.description" : {
      "comment" : "Description of a museum-themed instruction card.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أهلاً بك في متحفك الصغير! ضع روائعك على الرفوف وأرِ الجميع بفخر ما صنعته 🌟\n\nأنت الفنان!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome to your mini museum! Place your masterpieces on the shelves and proudly show everyone what you created 🌟 You are the artist!"
          }
        }
      }
    },
    "instruction.museum.title" : {
      "comment" : "Title for an instruction card that guides the user to a museum.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "متحفك الصغير"
          }
