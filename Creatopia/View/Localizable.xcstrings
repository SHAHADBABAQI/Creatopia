    "Here are your masterpieces!" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هاهي تحفتك"
          }
        }
      }
    },
    "instruction.board.description" : {
      "comment" : "Description for the \"Board\" instruction card.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر على اللوحة وابدأ الرسم مباشرةً على جهاز iPad! أطلق العنان لخيالك وابتكر ما يحلو لك ✨\n\nلا توجد قواعد، فقط الإبداع!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the board and start drawing right on your iPad! Use your imagination and create anything you like ✨ \n\nThere are no rules just creativity!"
          }
        }
      }
    },
    "instruction.board.title" : {
      "comment" : "Title for an instruction card in the \"Room\" view.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اللوحة الإبداعية"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Creative Board"
          }
        }
      }
    },
    "instruction.box.description" : {
      "comment" : "Description of a room instruction card related to a box.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا صندوق كنوزك الخاص! جميع إبداعاتك محفوظة هنا بأمان 💛\n \nلذا لن تفقد أفكارك الرائعة أبدًا."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is your special treasure box! All your creations are saved here safely 💛 So you’ll never lose your amazing ideas."
          }
        }
      }
    },
    "instruction.box.title" : {
      "comment" : "Title of an instruction card that guides the user to a box.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
