        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Mini Museum"
          }
        }
      }
    },
    "instruction.table.description" : {
      "comment" : "Description of the \"Table\" instruction card in the RoomView.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر على الطاولة و رج جهازك! 🫧\n\nستظهر فقاعات تحتوي على أدوات مفاجئة.\n\nابحث عن هذه الأدوات حولك وابدأ ببناء وحشك الخاص! 👾\n\nعندما تنتهي...\n\n📸 التقط صورة لتحفتك الفنية"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the table and shake your device! 🫧\n\nMagical bubbles will appear with surprise tools.\nFind these tools around you and start building your very own monster! 👾\n\nWhen you finish…\n📸 Take a photo of your masterpiece"
          }
        }
      }
    },
    "instruction.table.title" : {
      "comment" : "Title of an instruction card in the \"Room\" view that instructs the user to sit at the table.",
